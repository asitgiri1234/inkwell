{
  "name": "inkwell-server",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "coverage": "jest --coverage --runInBand --forceExit",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.10.0",
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.18.2",
    "jsonwebtoken": "9.0.2",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.0.3",
    "prisma": "5.10.0",
    "supertest": "6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  }
}